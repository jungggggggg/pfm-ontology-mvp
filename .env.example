# Optional: OpenAI-compatible endpoint. This also works with local Ollama/OpenRouter/vLLM endpoints
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Extractor selection: auto | llm | rule
EXTRACTOR=auto

# Embedding model from Hugging Face / Sentence Transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Acceptance threshold
AUTO_ACCEPT_CONFIDENCE=0.82
FUZZY_MATCH_THRESHOLD=90
SEMANTIC_MATCH_THRESHOLD=0.86

# Optional: limit how many chunks are sent to the LLM per document when debugging
MAX_CHUNKS_PER_DOC=
