# Extractor selection: local_llm | llm | rule | auto
EXTRACTOR=local_llm

# Local LLM settings
LOCAL_LLM_MODEL_PATH=/absolute/path/to/Meta-Llama-3.1-8B-Instruct
LOCAL_LLM_TORCH_DTYPE=bfloat16
LOCAL_LLM_MAX_NEW_TOKENS=900
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_TOP_P=0.9

# Optional: OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Embedding model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Acceptance threshold
AUTO_ACCEPT_CONFIDENCE=0.82
FUZZY_MATCH_THRESHOLD=90
SEMANTIC_MATCH_THRESHOLD=0.86

# Optional: limit how many chunks are sent to the LLM per document when debugging
MAX_CHUNKS_PER_DOC=